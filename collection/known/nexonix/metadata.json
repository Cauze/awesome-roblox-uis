{
    "id": "nexonix",
    "name": "Nexonix",
    "author": {
        "name": "samet",
        "url": "https://github.com/sametexe001"
    },
    "source": "https://raw.githubusercontent.com/sametexe001/sametlibs/main/nexonix/Library.lua",
    "loadstring": "loadstring(game:HttpGet(\"https://raw.githubusercontent.com/sametexe001/sametlibs/main/nexonix/Library.lua\"))()",
    "preview": "",
    "description": "Premium Roblox UI library with modern design and animations",
    "widgets": {
        "Window": {
            "description": "Main UI container with tabs, search, and settings",
            "methods": ["Create", "Tab"]
        },
        "Tab": {
            "description": "Tab page with icons and two-column layout",
            "methods": ["Section"]
        },
        "Section": {
            "description": "Container for widgets with name and column placement",
            "methods": ["Toggle", "Slider", "RangeSlider", "Button", "Dropdown", "Label", "Textbox", "Keybind", "Colorpicker"]
        },
        "Toggle": {
            "description": "On/off toggle with optional colorpicker and keybind",
            "signatures": ["Name, Default, Callback", "Name, Default, Flag, Callback"]
        },
        "Slider": {
            "description": "Single value slider with min/max/decimals/suffix",
            "signatures": ["Name, Min, Max, Default, Callback"]
        },
        "RangeSlider": {
            "description": "Dual-handle slider for min/max range",
            "signatures": ["Name, Min, Max, Default{Min,Max}, Callback"]
        },
        "Button": {
            "description": "Clickable button with callback",
            "signatures": ["Name, Callback", "Name, Tooltip, Callback"]
        },
        "Dropdown": {
            "description": "Dropdown selection with items array",
            "signatures": ["Name, Items, Default, Callback"]
        },
        "Label": {
            "description": "Static text label with optional colorpicker/keybind",
            "signatures": ["Name"]
        },
        "Textbox": {
            "description": "Text input field with placeholder and callback",
            "signatures": ["Name, Flag, Placeholder, Callback"]
        },
        "Colorpicker": {
            "description": "Color picker with hue/saturation/alpha controls",
            "signatures": ["Name, Flag, Default, Alpha, Callback"]
        },
        "Keybind": {
            "description": "Keybind selector with Toggle/Hold modes",
            "signatures": ["Name, Flag, Default, Mode, Callback"]
        }
    },
    "features": [
        "Draggable and resizable window",
        "Search functionality per tab",
        "Built-in settings (Configs, Theme, Other)",
        "Config save/load system",
        "Notifications",
        "Watermark",
        "Keybind list overlay",
        "Tooltip system",
        "Theme customization",
        "Animation customization"
    ],
    "theme": {
        "Background": "rgb(24, 26, 30)",
        "Inline": "rgb(29, 30, 36)",
        "Accent": "rgb(78, 95, 255)",
        "Tab": "rgb(34, 37, 57)",
        "DarkIcon": "rgb(64, 64, 73)",
        "Element": "rgb(38, 38, 50)",
        "Liner": "rgb(39, 39, 46)",
        "Outline": "rgb(47, 49, 53)",
        "DarkText": "rgb(108, 109, 116)",
        "Text": "rgb(255, 255, 255)",
        "Toggle": "rgb(57, 59, 75)",
        "HoveredElement": "rgb(46, 46, 54)"
    },
    "files": {
        "Example.lua": "Complete example demonstrating all widgets"
    }
}