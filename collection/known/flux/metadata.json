{
    "id": "flux",
    "name": "Flux",
    "author": {
        "name": "dawid-scripts",
        "url": "https://github.com/dawid-scripts"
    },
    "source": "https://github.com/CyanLtd/FluxLib",
    "preview": "https://raw.githubusercontent.com/CyanLtd/FluxLib/main/Loader",
    "description": "Feature-rich Roblox UI library with modern design. Includes Window, Tab, Button, Toggle, Slider, Dropdown, Colorpicker, Keybind, Label, Textbox, and Line widgets.",
    "widgets": [
        "Window",
        "Tab",
        "Button",
        "Toggle",
        "Slider",
        "Dropdown",
        "Colorpicker",
        "Keybind",
        "Label",
        "Textbox",
        "Line",
        "Notification"
    ],
    "apiSignature": {
        "Window": "Flux:Window(text, bottom, mainclr, toclose)",
        "Tab": "Tab:Tab(text, ico)",
        "Button": "Tab:Button(text, desc, callback)",
        "Toggle": "Tab:Toggle(text, desc, default, callback)",
        "Slider": "Tab:Slider(text, desc, min, max, start, callback)",
        "Dropdown": "Tab:Dropdown(text, list, callback)",
        "Colorpicker": "Tab:Colorpicker(text, preset, callback)",
        "Keybind": "Tab:Bind(text, presetbind, callback)",
        "Label": "Tab:Label(text)",
        "Textbox": "Tab:Textbox(text, desc, disapper, callback)",
        "Line": "Tab:Line()",
        "Notification": "Flux:Notification(desc, buttontitle)"
    },
    "colorScheme": {
        "background": "rgb(50, 53, 59)",
        "sidebar": "rgb(47, 49, 54)",
        "element": "rgb(64, 68, 75)",
        "accent": "rgb(66, 134, 255)",
        "text": "rgb(255, 255, 255)"
    },
    "tags": ["ui-library", "roblox", "featured"]
}