---
import { readdir, readFile } from "node:fs/promises";
import path from "node:path";
import '../styles/global.css';

type UIEntry = {
	id: string;
	name: string;
	author: { name: string; url: string };
	source: string;
	preview: string;
};

const collectionDir = path.resolve(process.cwd(), "../collection");
const dirs = await readdir(collectionDir, { withFileTypes: true });

const entries: UIEntry[] = (
	await Promise.all(
		dirs
			.filter((dirent) => dirent.isDirectory())
			.map(async (dirent) => {
				const metadataPath = path.join(collectionDir, dirent.name, "metadata.json");
				const raw = await readFile(metadataPath, "utf-8");
				return JSON.parse(raw) as UIEntry;
			}),
	)
).sort((a, b) => a.name.localeCompare(b.name));
const repoRawBase = "https://raw.githubusercontent.com/Cauze/awesome-roblox-uis/refs/heads/main";

---

<html lang="en" data-theme="dark">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Awesome Roblox UIs</title>
		<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
	</head>
	<body class="min-h-screen bg-base-100">
		<main class="max-w-[1100px] mx-auto px-5 py-12">
			<div class="flex flex-col items-center gap-4 mb-8">
				<h1 class="text-4xl font-bold text-center">Awesome Roblox UIs</h1>
				<div class="flex gap-3">
					<input id="search" type="text" placeholder="Search by name, author, or id..." class="input input-bordered w-full max-w-md" />
					<button id="theme-toggle" class="btn btn-square">
						<svg id="sun-icon" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
						</svg>
						<svg id="moon-icon" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
						</svg>
					</button>
				</div>
			</div>
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
				{
					entries.map((entry) => (
						<article
							class="card bg-base-200 border border-base-300 shadow-lg rounded-xl"
							data-id={entry.id.toLowerCase()}
							data-name={entry.name.toLowerCase()}
							data-author={entry.author ? entry.author.name.toLowerCase() : ''}
						>
							<figure class="rounded-t-xl">
								<img src={entry.preview || 'https://via.placeholder.com/400x200?text=No+Preview'} alt={`${entry.name} preview`} class="w-full h-40 object-cover" loading="lazy" />
							</figure>
							<div class="card-body p-4">
								<div class="flex items-center justify-between gap-2">
									<a class="card-title text-lg font-semibold hover:underline" href={entry.source} target="_blank" rel="noreferrer">{entry.name}</a>
									<a href={entry.source} target="_blank" rel="noreferrer" class="text-primary opacity-80 hover:opacity-100" aria-label={`Open ${entry.name} source`}>
										<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
										</svg>
									</a>
								</div>
								{entry.author && (
									<p class="text-sm text-base-content/60">
										by <a href={entry.author.url} target="_blank" rel="noreferrer" class="text-primary hover:underline">{entry.author.name}</a>
									</p>
								)}
								<div class="flex gap-3 mt-1 text-sm">
									<a href={`${repoRawBase}/collection/${entry.id}/source.lua`} target="_blank" rel="noreferrer" class="text-primary hover:underline">Source</a>
									<a href={`${repoRawBase}/collection/${entry.id}/example.lua`} target="_blank" rel="noreferrer" class="text-primary hover:underline">Example</a>
								</div>
								<div class="mt-3 bg-base-300 rounded-lg overflow-hidden border border-base-300">
									<div class="flex items-center justify-between px-3 py-1.5 bg-base-300/50 border-b border-base-300 text-xs text-base-content/60">
										<span>Loadstring</span>
										<button class="copy-btn btn btn-ghost btn-xs" data-code={`loadstring(game:HttpGet("${repoRawBase}/collection/${entry.id}/example.lua"))()`}>Copy</button>
									</div>
									<pre class="px-3 py-2 text-xs text-base-content/80 font-mono overflow-x-auto whitespace-nowrap">{`loadstring(game:HttpGet("${repoRawBase}/collection/${entry.id}/example.lua"))()`}</pre>
								</div>
							</div>
						</article>
					))
				}
			</div>
		</main>
		<script>
			const searchInput = document.getElementById("search") as HTMLInputElement;
			const cards = Array.from(document.querySelectorAll(".card"));
			const themeToggle = document.getElementById("theme-toggle");
			const html = document.documentElement;
			const sunIcon = document.getElementById("sun-icon");
			const moonIcon = document.getElementById("moon-icon");

			searchInput?.addEventListener("input", () => {
				const q = (searchInput.value || "").trim().toLowerCase();
				for (const card of cards) {
					const haystack = [
						card.getAttribute("data-id") || "",
						card.getAttribute("data-name") || "",
						card.getAttribute("data-author") || "",
					].join(" ");
					(card as HTMLElement).style.display = q.length > 0 && !haystack.includes(q) ? "none" : "";
				}
			});

			themeToggle?.addEventListener("click", () => {
				const isDark = html.getAttribute("data-theme") === "dark";
				html.setAttribute("data-theme", isDark ? "light" : "dark");
				sunIcon?.classList.toggle("hidden", isDark);
				moonIcon?.classList.toggle("hidden", !isDark);
			});

			document.addEventListener("click", (e) => {
				const btn = (e.target as Element).closest(".copy-btn");
				if (!btn) return;
				const code = (btn as HTMLElement).getAttribute("data-code");
				if (!code) return;
				navigator.clipboard.writeText(code).then(() => {
					btn.textContent = "Copied!";
					setTimeout(() => {
						btn.textContent = "Copy";
					}, 1500);
				});
			});
		</script>
	</body>
</html>