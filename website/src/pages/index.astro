---
import { readdir, readFile } from "node:fs/promises";
import path from "node:path";
import '../styles/global.css';

type UIEntry = {
	id: string;
	name: string;
	author: { name: string; url: string };
	source: string;
	preview: string;
};

const collectionDir = path.resolve(process.cwd(), "../collection");
const dirs = await readdir(collectionDir, { withFileTypes: true });

const entries: UIEntry[] = (
	await Promise.all(
		dirs
			.filter((dirent) => dirent.isDirectory())
			.map(async (dirent) => {
				const metadataPath = path.join(collectionDir, dirent.name, "metadata.json");
				const raw = await readFile(metadataPath, "utf-8");
				return JSON.parse(raw) as UIEntry;
			}),
	)
).sort((a, b) => a.name.localeCompare(b.name));
const repoRawBase = "https://raw.githubusercontent.com/Cauze/awesome-roblox-uis/refs/heads/main";

---

<html lang="en" data-theme="dark">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Awesome Roblox UIs</title>
		<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
	</head>
	<body class="min-h-screen bg-base-100">
		<header class="flex justify-end items-center gap-2 p-4">
			<a href="https://github.com/Cauze/awesome-roblox-uis" target="_blank" rel="noreferrer" class="btn btn-square btn-ghost" aria-label="GitHub">
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5">
					<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
				</svg>
			</a>
			<button id="theme-toggle" class="btn btn-square btn-ghost">
				<svg id="sun-icon" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
				</svg>
				<svg id="moon-icon" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
				</svg>
			</button>
		</header>
		<main class="w-full max-w-[1400px] mx-auto px-6 pb-12">
			<div class="flex flex-col items-center gap-6 mb-8">
				<h1 class="text-4xl font-bold text-center">Awesome Roblox UIs</h1>
				<input id="search" type="text" placeholder="Search by name or author..." class="input input-bordered w-full max-w-2xl" />
			</div>
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
				{
					entries.map((entry) => (
						<article
							class="card bg-base-200 border border-base-300 shadow-lg rounded-xl"
							data-id={entry.id.toLowerCase()}
							data-name={entry.name.toLowerCase()}
							data-author={entry.author ? entry.author.name.toLowerCase() : ''}
						>
							<figure class="rounded-t-xl relative">
								{entry.preview ? (
									<img src={entry.preview} alt={`${entry.name} preview`} class="w-full h-40 object-cover" loading="lazy" />
								) : (
									<div class="w-full h-40 bg-base-300 flex items-center justify-center text-base-content/40">
										<span class="text-sm font-medium">No preview</span>
									</div>
								)}
								{entry.author && (
									<a href={entry.author.url} target="_blank" rel="noreferrer" class="badge badge-neutral bg-neutral/70 border-neutral/50 absolute top-3 right-3 text-xs no-underline hover:bg-neutral/80">
										{entry.author.name}
									</a>
								)}
							</figure>
							<div class="card-body p-4">
								<div class="flex items-center justify-between gap-2">
									<a class="card-title text-lg font-semibold hover:underline" href={entry.source} target="_blank" rel="noreferrer">{entry.name}</a>
									<a href={entry.source} target="_blank" rel="noreferrer" class="text-primary opacity-80 hover:opacity-100" aria-label={`Open ${entry.name} source`}>
										<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
										</svg>
									</a>
								</div>
								<div class="flex gap-3 mt-1 text-sm">
									<a href={`${repoRawBase}/collection/${entry.id}/source.lua`} target="_blank" rel="noreferrer" class="text-primary hover:underline">Source</a>
									<a href={`${repoRawBase}/collection/${entry.id}/example.lua`} target="_blank" rel="noreferrer" class="text-primary hover:underline">Example</a>
								</div>
							</div>
						</article>
					))
				}
			</div>
		</main>
		<script>
			const searchInput = document.getElementById("search") as HTMLInputElement;
			const cards = Array.from(document.querySelectorAll(".card"));
			const themeToggle = document.getElementById("theme-toggle");
			const html = document.documentElement;
			const sunIcon = document.getElementById("sun-icon");
			const moonIcon = document.getElementById("moon-icon");

			function fuzzyMatch(query: string, target: string): boolean {
				const q = query.toLowerCase();
				const t = target.toLowerCase();
				let qi = 0;
				for (let i = 0; i < t.length && qi < q.length; i++) {
					if (t[i] === q[qi]) qi++;
				}
				return qi === q.length;
			}

			searchInput?.addEventListener("input", () => {
				const q = (searchInput.value || "").trim().toLowerCase();
				for (const card of cards) {
					const name = card.getAttribute("data-name") || "";
					const author = card.getAttribute("data-author") || "";
					const match = fuzzyMatch(q, name) || fuzzyMatch(q, author);
					(card as HTMLElement).style.display = q.length > 0 && !match ? "none" : "";
				}
			});

			themeToggle?.addEventListener("click", () => {
				const isDark = html.getAttribute("data-theme") === "dark";
				html.setAttribute("data-theme", isDark ? "light" : "dark");
				sunIcon?.classList.toggle("hidden", isDark);
				moonIcon?.classList.toggle("hidden", !isDark);
			});
		</script>
	</body>
</html>