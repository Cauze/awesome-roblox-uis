---
import { readdir, readFile } from "node:fs/promises";
import path from "node:path";

type UIEntry = {
	id: string;
	name: string;
	author: { name: string; url: string };
	source: string;
	preview: string;
};

const knownDir = path.resolve(process.cwd(), "../collection/known");
const dirs = await readdir(knownDir, { withFileTypes: true });

const entries: UIEntry[] = (
	await Promise.all(
		dirs
			.filter((dirent) => dirent.isDirectory())
			.map(async (dirent) => {
				const metadataPath = path.join(knownDir, dirent.name, "metadata.json");
				const raw = await readFile(metadataPath, "utf-8");
				return JSON.parse(raw) as UIEntry;
			}),
	)
).sort((a, b) => a.name.localeCompare(b.name));
const repoRawBase = "https://raw.githubusercontent.com/Cauze/awesome-roblox-uis/refs/heads/main";

---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Awesome Roblox UIs</title>
		<style>
			:root {
				--bg: #0a101d;
				--panel: #121d32;
				--panel-2: #162442;
				--text: #ecf2ff;
				--muted: #8fa4c7;
				--line: #2a3d66;
				--accent: #6ee7b7;
			}

			* {
				box-sizing: border-box;
			}

			body {
				margin: 0;
				font-family: "Space Grotesk", "Segoe UI", sans-serif;
				color: var(--text);
				background:
					radial-gradient(1200px 500px at 10% -20%, #14305f 0%, transparent 60%),
					radial-gradient(900px 400px at 100% 0%, #173a66 0%, transparent 60%),
					var(--bg);
				background-repeat: no-repeat;
				background-size: 100% 100%;
				min-height: 100vh;
			}

			main {
				max-width: 1100px;
				margin: 0 auto;
				padding: 48px 20px 72px;
			}

			h1 {
				margin: 0;
				font-size: clamp(1.9rem, 3vw, 2.6rem);
				letter-spacing: 0.02em;
				text-align: center;
			}

			.search-wrap {
				margin-top: 20px;
				display: flex;
				justify-content: center;
			}

			.search {
				width: min(560px, 100%);
				border: 1px solid var(--line);
				background: rgba(7, 17, 34, 0.75);
				color: var(--text);
				border-radius: 12px;
				padding: 12px 14px;
				font-size: 0.98rem;
				outline: none;
			}

			.search:focus {
				border-color: #3f8cff;
			}

			.grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
				gap: 16px;
				margin-top: 28px;
			}

			.card {
				background: linear-gradient(180deg, var(--panel-2), var(--panel));
				border: 1px solid var(--line);
				border-radius: 16px;
				overflow: hidden;
				box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25);
			}

			.card img {
				width: 100%;
				height: 170px;
				object-fit: cover;
				display: block;
				background: #090f19;
			}

			.content {
				padding: 14px;
			}

			.title {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 10px;
				margin: 0 0 6px;
			}

			.title-link {
				font-size: 1.15rem;
				font-weight: 600;
				color: var(--text);
				text-decoration: none;
			}

			.title-link:hover {
				text-decoration: underline;
			}

			.external {
				font-size: 0.95rem;
				opacity: 0.9;
			}

			.meta {
				font-size: 0.92rem;
				color: var(--muted);
				margin: 0 0 12px;
			}

			.links {
				display: flex;
				gap: 10px;
			}

			a {
				color: var(--accent);
				text-decoration: none;
				font-weight: 600;
			}

			a:hover {
				text-decoration: underline;
			}

			.hidden {
				display: none;
			}
		</style>
	</head>
	<body>
		<main>
			<h1>Awesome Roblox UIs</h1>
			<div class="search-wrap">
				<input id="search" class="search" type="search" placeholder="Search by name, author, or id..." />
			</div>
			<section class="grid">
				{
					entries.map((entry) => (
						<article
							class="card"
							data-id={entry.id.toLowerCase()}
							data-name={entry.name.toLowerCase()}
							data-author={entry.author.name.toLowerCase()}
						>
							<img src={entry.preview} alt={`${entry.name} preview`} loading="lazy" />
							<div class="content">
								<h2 class="title">
									<a class="title-link" href={entry.source} target="_blank" rel="noreferrer">{entry.name}</a>
									<a class="external" href={entry.source} target="_blank" rel="noreferrer" aria-label={`Open ${entry.name} source`}>
										↗
									</a>
								</h2>
								<p class="meta">
									by <a href={entry.author.url} target="_blank" rel="noreferrer">{entry.author.name}</a>
								</p>
								<div class="links">
									<a
										href={`${repoRawBase}/collection/known/${entry.id}/source.lua`}
										target="_blank"
										rel="noreferrer"
									>
										Source
									</a>
									<a
										href={`${repoRawBase}/collection/known/${entry.id}/example.lua`}
										target="_blank"
										rel="noreferrer"
									>
										Example
									</a>
								</div>
							</div>
						</article>
					))
				}
			</section>
		</main>
		<script>
			const searchInput = document.getElementById("search");
			const cards = Array.from(document.querySelectorAll(".card"));

			searchInput?.addEventListener("input", () => {
				const q = (searchInput.value || "").trim().toLowerCase();
				for (const card of cards) {
					const haystack = [
						card.getAttribute("data-id") || "",
						card.getAttribute("data-name") || "",
						card.getAttribute("data-author") || "",
					].join(" ");
					card.classList.toggle("hidden", q.length > 0 && !haystack.includes(q));
				}
			});
		</script>
	</body>
</html>
